<UserControl x:Class="LuluPet.App.Controls.ClipboardBubblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Height="292"
             Focusable="True">
    <Border Background="#FAFFFFFF"
            BorderBrush="#FFE6C56F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#7F5A3A18"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="剪切板"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Content="x"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FF7C5A2C"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click" />
            </Grid>

            <Grid Grid.Row="2">
                <ListBox x:Name="HistoryListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         SelectionChanged="HistoryListBox_SelectionChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#14E6C56F"
                                    BorderBrush="#33C99A3A"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Preview}"
                                               TextWrapping="Wrap"
                                               MaxHeight="54"
                                               Foreground="#FF5A3A18" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding CapturedAtText}"
                                               FontSize="12"
                                               Foreground="#FF8A642A"
                                               HorizontalAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="EmptyText"
                           Text="还没有剪切板记录"
                           Foreground="#FF8A642A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <TextBlock x:Name="CountText"
                       Grid.Row="4"
                       FontSize="12"
                       Foreground="#FF8A642A"
                       HorizontalAlignment="Right" />
        </Grid>
    </Border>
</UserControl>
