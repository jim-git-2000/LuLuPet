<Window x:Class="LuluPet.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LuluPet.App.Controls"
        Title="LuluPet"
        Width="340"
        Height="390"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Focusable="True">
    <Grid x:Name="RootLayout"
          Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PetColumn"
                              Width="340" />
            <ColumnDefinition x:Name="ToolPanelColumn"
                              Width="0" />
        </Grid.ColumnDefinitions>

        <controls:SpeechBubble x:Name="SpeechBubble"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,8,0,0"
                               Visibility="Collapsed" />
        <controls:ReminderBubblePanel x:Name="ReminderPanel"
                                      Grid.Column="1"
                                      Panel.ZIndex="20"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Bottom"
                                      Margin="8,0,16,10"
                                      Visibility="Collapsed" />
        <controls:ClipboardBubblePanel x:Name="ClipboardPanel"
                                       Grid.Column="1"
                                       Panel.ZIndex="20"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0,16,10"
                                       Visibility="Collapsed" />
        <controls:FileTransitBubblePanel x:Name="FileTransitPanel"
                                         Grid.Column="1"
                                         Panel.ZIndex="20"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Bottom"
                                         Margin="8,0,16,10"
                                         Visibility="Collapsed" />
        <Image x:Name="PetImage"
               Grid.Column="0"
               Width="300"
               Height="300"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,10"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="PetMirrorTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Image.RenderTransform>
        </Image>
        <Border x:Name="MissingAssetFallback"
                Grid.Column="0"
                Width="220"
                Height="88"
                Background="#CCFFFFFF"
                BorderBrush="#FFB7C7D9"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="LuluPet"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#FF2F3A45"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Missing lulu_idle_0001.png"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="#FF64748B"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
