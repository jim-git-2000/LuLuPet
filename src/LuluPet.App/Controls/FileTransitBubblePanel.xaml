<UserControl x:Class="LuluPet.App.Controls.FileTransitBubblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Height="292"
             Focusable="True"
             AllowDrop="True"
             PreviewKeyDown="FileTransitPanel_PreviewKeyDown"
             DragEnter="FileTransitPanel_DragEnter"
             DragOver="FileTransitPanel_DragOver"
             Drop="FileTransitPanel_Drop">
    <Border Background="#FAFFFFFF"
            BorderBrush="#FFE6C56F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#7F5A3A18"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="4" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="文件中转站"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Content="x"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FF7C5A2C"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click" />
            </Grid>

            <Button Grid.Row="2"
                    Height="28"
                    Padding="10,0"
                    HorizontalAlignment="Left"
                    Content="打开文件夹"
                    Foreground="#FF5A3A18"
                    Background="#18E6C56F"
                    BorderBrush="#66C99A3A"
                    Click="OpenFolderButton_Click" />

            <Grid Grid.Row="4">
                <ListBox x:Name="FileListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         MouseDoubleClick="FileListBox_MouseDoubleClick"
                         PreviewMouseRightButtonUp="FileListBox_PreviewMouseRightButtonUp"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#14E6C56F"
                                    BorderBrush="#33C99A3A"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#FF5A3A18" />
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ModifiedAtText}"
                                                   FontSize="12"
                                                   Foreground="#FF8A642A" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SizeText}"
                                                   FontSize="12"
                                                   Foreground="#FF8A642A" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="EmptyText"
                           Text="拖入文件暂存到这里"
                           Foreground="#FF8A642A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <TextBlock x:Name="StatusText"
                       Grid.Row="6"
                       FontSize="12"
                       Foreground="#FF5A3A18"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Stretch" />

            <TextBlock x:Name="FolderText"
                       Grid.Row="8"
                       FontSize="11"
                       Foreground="#FF8A642A"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Stretch" />
        </Grid>
    </Border>
</UserControl>
