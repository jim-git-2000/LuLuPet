<UserControl x:Class="LuluPet.App.Controls.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="48"
             Height="26"
             Focusable="True"
             Cursor="Hand"
             MouseLeftButtonUp="ToggleSwitch_MouseLeftButtonUp"
             KeyDown="ToggleSwitch_KeyDown">
    <Grid>
        <Border x:Name="Track"
                Height="24"
                CornerRadius="12"
                Background="#FFE5E7EB"
                BorderBrush="#FFD1D5DB"
                BorderThickness="1" />
        <Ellipse x:Name="Knob"
                 Width="20"
                 Height="20"
                 HorizontalAlignment="Left"
                 Margin="3,0,0,0"
                 Fill="#FFFFFFFF"
                 Stroke="#FFD1D5DB"
                 StrokeThickness="1">
            <Ellipse.RenderTransform>
                <TranslateTransform x:Name="KnobTransform" />
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
