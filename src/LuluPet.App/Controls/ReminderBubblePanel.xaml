<UserControl x:Class="LuluPet.App.Controls.ReminderBubblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LuluPet.App.Controls"
             Width="300"
             Height="292"
             Focusable="True">
    <Border Background="#FAFFFFFF"
            BorderBrush="#FFE6C56F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#7F5A3A18"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="专注提醒"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Content="x"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FF7C5A2C"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click" />
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="番茄钟"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <controls:ToggleSwitch x:Name="PomodoroToggle"
                                       Grid.Column="1" />

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="专注"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBox x:Name="PomodoroMinutesTextBox"
                             Width="46"
                             Height="26"
                             Margin="8,0,6,0"
                             HorizontalContentAlignment="Center"
                             MaxLength="3"
                             DataObject.Pasting="IntegerTextBox_Pasting"
                             PreviewTextInput="IntegerTextBox_PreviewTextInput"
                             TextChanged="PomodoroMinutesTextBox_TextChanged" />
                    <TextBlock Text="分钟"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBlock Text="  休息"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBox x:Name="PomodoroRestMinutesTextBox"
                             Width="46"
                             Height="26"
                             Margin="8,0,6,0"
                             HorizontalContentAlignment="Center"
                             MaxLength="3"
                             DataObject.Pasting="IntegerTextBox_Pasting"
                             PreviewTextInput="IntegerTextBox_PreviewTextInput"
                             TextChanged="PomodoroRestMinutesTextBox_TextChanged" />
                    <TextBlock Text="分钟"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                </StackPanel>

                <TextBlock x:Name="PomodoroStatusText"
                           Grid.Row="4"
                           Grid.ColumnSpan="2"
                           Foreground="#FF8A642A"
                           FontSize="12" />
            </Grid>

            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="喝水提醒"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <controls:ToggleSwitch x:Name="WaterToggle"
                                       Grid.Column="1" />

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="每"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBox x:Name="WaterMinutesTextBox"
                             Width="46"
                             Height="26"
                             Margin="8,0,6,0"
                             HorizontalContentAlignment="Center"
                             MaxLength="3"
                             DataObject.Pasting="IntegerTextBox_Pasting"
                             PreviewTextInput="IntegerTextBox_PreviewTextInput"
                             TextChanged="WaterMinutesTextBox_TextChanged" />
                    <TextBlock Text="分钟"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBlock x:Name="WaterStatusText"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF8A642A"
                               FontSize="12" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="起立休息"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <controls:ToggleSwitch x:Name="StandToggle"
                                       Grid.Column="1" />

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="每"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBox x:Name="StandMinutesTextBox"
                             Width="46"
                             Height="26"
                             Margin="8,0,6,0"
                             HorizontalContentAlignment="Center"
                             MaxLength="3"
                             DataObject.Pasting="IntegerTextBox_Pasting"
                             PreviewTextInput="IntegerTextBox_PreviewTextInput"
                             TextChanged="StandMinutesTextBox_TextChanged" />
                    <TextBlock Text="分钟"
                               VerticalAlignment="Center"
                               Foreground="#FF6B4B21" />
                    <TextBlock x:Name="StandStatusText"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF8A642A"
                               FontSize="12" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
