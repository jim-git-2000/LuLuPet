<UserControl x:Class="LuluPet.App.Controls.SettingsBubblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Height="360"
             Focusable="True">
    <Border Background="#FAFFFFFF"
            BorderBrush="#FFE6C56F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#7F5A3A18"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="设置"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Content="x"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FF7C5A2C"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click" />
            </Grid>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="缩放"
                                   VerticalAlignment="Center"
                                   Foreground="#FF5A3A18" />
                        <Slider x:Name="ScaleSlider"
                                Grid.Column="1"
                                Minimum="0.3"
                                Maximum="1.5"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                ValueChanged="ScaleSlider_ValueChanged" />
                        <TextBlock x:Name="ScaleValueText"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="#FF8A642A" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="透明度"
                                   VerticalAlignment="Center"
                                   Foreground="#FF5A3A18" />
                        <Slider x:Name="OpacitySlider"
                                Grid.Column="1"
                                Minimum="0.35"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OpacitySlider_ValueChanged" />
                        <TextBlock x:Name="OpacityValueText"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="#FF8A642A" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="音量"
                                   VerticalAlignment="Center"
                                   Foreground="#FF5A3A18" />
                        <Slider x:Name="VolumeSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                ValueChanged="VolumeSlider_ValueChanged" />
                        <TextBlock x:Name="VolumeValueText"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="#FF8A642A" />
                    </Grid>

                    <CheckBox x:Name="ClickThroughCheckBox"
                              Content="点击穿透"
                              Margin="0,0,0,10"
                              Foreground="#FF5A3A18"
                              Checked="ClickThroughCheckBox_Changed"
                              Unchecked="ClickThroughCheckBox_Changed" />
                    <CheckBox x:Name="WalkModeCheckBox"
                              Content="散步模式"
                              Margin="0,0,0,10"
                              Foreground="#FF5A3A18"
                              Checked="WalkModeCheckBox_Changed"
                              Unchecked="WalkModeCheckBox_Changed" />
                    <CheckBox x:Name="AutoStartCheckBox"
                              Content="开机启动"
                              Margin="0,0,0,14"
                              Foreground="#FF5A3A18"
                              Checked="AutoStartCheckBox_Changed"
                              Unchecked="AutoStartCheckBox_Changed" />

                    <TextBlock Text="文件中转站"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               Margin="0,0,0,8" />
                    <TextBox x:Name="FileTransitFolderTextBox"
                             Height="28"
                             IsReadOnly="True"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="选择"
                                Height="28"
                                Click="BrowseFileTransitFolderButton_Click" />
                        <Button Grid.Column="2"
                                Content="默认"
                                Height="28"
                                Click="ResetFileTransitFolderButton_Click" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
