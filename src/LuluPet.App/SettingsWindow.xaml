<Window x:Class="LuluPet.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LuluPet 设置"
        Width="360"
        Height="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FFF8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="设置"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#FF1F2937" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="缩放"
                       VerticalAlignment="Center"
                       Foreground="#FF374151" />
            <Slider x:Name="ScaleSlider"
                    Grid.Column="1"
                    Minimum="0.3"
                    Maximum="1.5"
                    TickFrequency="0.05"
                    IsSnapToTickEnabled="True"
                    ValueChanged="ScaleSlider_ValueChanged" />
            <TextBlock x:Name="ScaleValueText"
                       Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#FF64748B" />
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="透明度"
                       VerticalAlignment="Center"
                       Foreground="#FF374151" />
            <Slider x:Name="OpacitySlider"
                    Grid.Column="1"
                    Minimum="0.35"
                    Maximum="1"
                    TickFrequency="0.05"
                    IsSnapToTickEnabled="True"
                    ValueChanged="OpacitySlider_ValueChanged" />
            <TextBlock x:Name="OpacityValueText"
                       Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#FF64748B" />
        </Grid>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="音量"
                       VerticalAlignment="Center"
                       Foreground="#FF374151" />
            <Slider x:Name="VolumeSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    TickFrequency="0.05"
                    IsSnapToTickEnabled="True"
                    ValueChanged="VolumeSlider_ValueChanged" />
            <TextBlock x:Name="VolumeValueText"
                       Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Foreground="#FF64748B" />
        </Grid>

        <StackPanel Grid.Row="8">
            <CheckBox x:Name="ClickThroughCheckBox"
                      Content="点击穿透"
                      Margin="0,0,0,12"
                      Checked="ClickThroughCheckBox_Changed"
                      Unchecked="ClickThroughCheckBox_Changed" />
            <CheckBox x:Name="AutoStartCheckBox"
                      Content="开机启动"
                      Checked="AutoStartCheckBox_Changed"
                      Unchecked="AutoStartCheckBox_Changed" />
        </StackPanel>

        <Grid Grid.Row="9"
              Margin="0,18,0,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="文件中转站"
                       Foreground="#FF374151" />
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="52" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FileTransitFolderTextBox"
                         Height="28"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="2"
                        Content="选择"
                        Height="28"
                        Click="BrowseFileTransitFolderButton_Click" />
                <Button Grid.Column="4"
                        Content="默认"
                        Height="28"
                        Click="ResetFileTransitFolderButton_Click" />
            </Grid>
        </Grid>

        <Button Grid.Row="10"
                Content="关闭"
                Width="86"
                Height="32"
                HorizontalAlignment="Right"
                Click="CloseButton_Click" />
    </Grid>
</Window>
