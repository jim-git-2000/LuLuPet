<UserControl x:Class="LuluPet.App.Controls.TutorialBubblePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Height="360"
             Focusable="True">
    <Border Background="#FAFFFFFF"
            BorderBrush="#FFE6C56F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,14"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect Color="#7F5A3A18"
                              BlurRadius="12"
                              ShadowDepth="3"
                              Opacity="0.18" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="教程"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#FF5A3A18"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Content="x"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#FF7C5A2C"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="CloseButton_Click" />
            </Grid>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="快捷键"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               Margin="0,0,0,8" />
                    <TextBlock Text="F：专注提醒面板。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21" />
                    <TextBlock Text="C：剪切板历史面板。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,4,0,0" />
                    <TextBlock Text="D：文件中转站面板。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,4,0,0" />
                    <TextBlock Text="W：让噜噜进入 Walk 状态。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,4,0,0" />
                    <TextBlock Text="I：回到 Idle 待机状态。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,4,0,0" />
                    <TextBlock Text="S：进入 Sleep 睡觉状态。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,4,0,14" />

                    <TextBlock Text="剪切板"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               Margin="0,0,0,8" />
                    <TextBlock Text="复制文本后，噜噜会记录最近 100 条文本。打开 C 面板后点击任意条目，会把该文本重新写回系统剪切板。剪切板历史只保存在本次运行中。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,0,0,14" />

                    <TextBlock Text="文件中转站"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               Margin="0,0,0,8" />
                    <TextBlock Text="打开 D 面板后，可以把文件拖进来暂存。拖入会复制文件，不会移动原文件。同名文件会自动追加序号。双击文件会打开；右键文件会复制该文件，可粘贴到其他位置。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21"
                               Margin="0,0,0,14" />

                    <TextBlock Text="托盘"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               Margin="0,0,0,8" />
                    <TextBlock Text="右下角托盘可以显示、隐藏、打开设置、查看教程、切换点击穿透和开机启动。设置里可以修改文件中转站文件夹。"
                               TextWrapping="Wrap"
                               Foreground="#FF6B4B21" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
