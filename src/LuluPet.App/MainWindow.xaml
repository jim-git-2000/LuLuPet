<Window x:Class="LuluPet.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LuluPet.App.Controls"
        Title="LuluPet"
        Width="340"
        Height="390"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Focusable="True">
    <Grid x:Name="RootLayout"
          Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="PetColumn"
                              Width="340" />
            <ColumnDefinition x:Name="ToolPanelColumn"
                              Width="0" />
        </Grid.ColumnDefinitions>

        <controls:SpeechBubble x:Name="SpeechBubble"
                               Grid.Column="0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,8,0,0"
                               Visibility="Collapsed" />
        <controls:ReminderBubblePanel x:Name="ReminderPanel"
                                      Grid.Column="1"
                                      Panel.ZIndex="20"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Bottom"
                                      Margin="8,0,16,10"
                                      Visibility="Collapsed" />
        <Border x:Name="ClipboardPanel"
                Grid.Column="1"
                Panel.ZIndex="20"
                Width="300"
                Height="292"
                Focusable="True"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8,0,16,10"
                Background="#FAFFFFFF"
                BorderBrush="#FFE6C56F"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#7F5A3A18"
                                  BlurRadius="12"
                                  ShadowDepth="3"
                                  Opacity="0.18" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="剪切板"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Width="24"
                            Height="24"
                            Content="x"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FF7C5A2C"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="ToolPanelCloseButton_Click" />
                </Grid>
                <TextBlock Grid.Row="2"
                           Text="剪切板历史将在 P19 接入。"
                           TextWrapping="Wrap"
                           Foreground="#FF6B4B21"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Grid.Row="4"
                           Text="C"
                           FontSize="12"
                           Foreground="#FF8A642A"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>
        <Border x:Name="FileTransitPanel"
                Grid.Column="1"
                Panel.ZIndex="20"
                Width="300"
                Height="292"
                Focusable="True"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8,0,16,10"
                Background="#FAFFFFFF"
                BorderBrush="#FFE6C56F"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#7F5A3A18"
                                  BlurRadius="12"
                                  ShadowDepth="3"
                                  Opacity="0.18" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="文件中转站"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#FF5A3A18"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Width="24"
                            Height="24"
                            Content="x"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#FF7C5A2C"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="ToolPanelCloseButton_Click" />
                </Grid>
                <TextBlock Grid.Row="2"
                           Text="文件列表将在 P20 接入。"
                           TextWrapping="Wrap"
                           Foreground="#FF6B4B21"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Grid.Row="4"
                           Text="D"
                           FontSize="12"
                           Foreground="#FF8A642A"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>
        <Image x:Name="PetImage"
               Grid.Column="0"
               Width="300"
               Height="300"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,10"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="PetMirrorTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Image.RenderTransform>
        </Image>
        <Border x:Name="MissingAssetFallback"
                Grid.Column="0"
                Width="220"
                Height="88"
                Background="#CCFFFFFF"
                BorderBrush="#FFB7C7D9"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="LuluPet"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#FF2F3A45"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Missing lulu_idle_0001.png"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="#FF64748B"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
